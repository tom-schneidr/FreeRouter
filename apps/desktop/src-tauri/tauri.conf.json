{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "FreeRouter",
  "version": "0.1.0",
  "identifier": "dev.freerouter.desktop",
  "build": {
    "devUrl": "http://127.0.0.1:8000/app",
    "beforeBuildCommand": "npm --workspace @freerouter/ui run build",
    "frontendDist": "../../ui/dist"
  },
  "app": {
    "windows": [
      {
        "title": "FreeRouter",
        "width": 1280,
        "height": 820,
        "minWidth": 900,
        "minHeight": 620,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": [
      "../../../dist-sidecar/freerouterd"
    ]
  }
}
