{
  "name": "freerouter-workspace",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/ui",
    "apps/desktop"
  ],
  "scripts": {
    "desktop:dev": "powershell -ExecutionPolicy Bypass -File dev-desktop.ps1",
    "build:desktop": "npm run build:sidecar && npm run build:web && npm --workspace @freerouter/desktop run build",
    "build:web": "npm --workspace @freerouter/ui run build",
    "build:sidecar": "powershell -ExecutionPolicy Bypass -File scripts/build-sidecar.ps1",
    "icons:sync": ".venv\\Scripts\\python.exe -m app.desktop_icon --sync-all",
    "stop": "powershell -ExecutionPolicy Bypass -File scripts/stop-all-freerouter.ps1",
    "check:desktop": "cargo check --manifest-path apps/desktop/src-tauri/Cargo.toml",
    "typecheck:web": "npm --workspace @freerouter/ui run typecheck",
    "test:web": "npm --workspace @freerouter/ui run test"
  },
  "engines": {
    "node": ">=20"
  }
}
