CEREBRAS_API_KEY=
GROQ_API_KEY=
GEMINI_API_KEY=
NVIDIA_API_KEY=
OPENROUTER_API_KEY=

DATABASE_PATH=./data/gateway.sqlite3
MODEL_CATALOG_PATH=./data/model_catalog.json
REQUEST_TIMEOUT_SECONDS=90
MAX_CONCURRENT_REQUESTS=20
STREAMING_RELEASE_SLOT_AFTER_ROUTE_SELECTED=true
